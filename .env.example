# Safe local defaults. Copy to .env and fill secrets locally.
# Never commit real keys or wallet credentials.

# Core mode
MODE=paper
LIVE_TRADING=false
ENABLE_REAL_LIVE_TRADING=false
RUN_ID=

# Steam / feeds
STEAM_API_KEY=replace_me
STEAM_POLL_SECONDS=3.0
WS_RECONNECT_SECONDS=5
MAX_STEAM_AGE_MS=25000
MAX_SOURCE_UPDATE_AGE_SEC=30
MAX_BOOK_AGE_MS=90000
REQUIRE_TOP_LIVE_FOR_SIGNALS=true
REALTIME_STATS_ENABLED=true

# Event strategy gates
EVENT_DETECTORS_ENABLED=true
ALLOW_EVENT_TRADES=true
ALLOW_GAME_OVER_ONLY=false
ALLOW_CONFIRMATION_ONLY_LIVE_TRADES=false
DISABLE_STRUCTURE_TRADES=false
TRADE_EVENTS=
MIN_LAG=0.05
MIN_EXECUTABLE_EDGE=0.05
MIN_ASK_SIZE_USD=25
MAX_SPREAD=0.15
DEFAULT_MAX_FILL_PRICE=0.80
PRICE_LOOKBACK_SEC=10
PAPER_TRADE_SIZE_USD=25
PAPER_SLIPPAGE_CENTS=0.01
PAPER_EXECUTION_DELAY_MS=0

# Live safety rails. Keep real live trading false unless explicitly promoting.
MAX_TOTAL_LIVE_USD=1000
MAX_DAILY_DRAWDOWN_USD=25
MAX_TRADE_USD=1
MAX_OPEN_POSITIONS=1
MAX_OPEN_USD_PER_MATCH=150
ORDER_TYPE=FAK
LIVE_TICK_SIZE=0.01
LIVE_SAFETY_MARGIN=0.02
LIVE_REQUIRE_CADENCE_SCHEMA=true
LIVE_ALLOWED_CADENCE_QUALITIES=direct,normal
LIVE_MIN_EVENT_QUALITY=0.60

# Value strategy
VALUE_ENGINE_ENABLED=true
ENABLE_VALUE_TRADING=true
VALUE_MIN_EDGE=0.10
VALUE_MAX_PRICE=0.84
VALUE_MIN_NW_LEAD=3000
VALUE_MIN_GAME_TIME=600
VALUE_MIN_FAIR=0.0
VALUE_MIN_PRICE=0.50
VALUE_MAX_EDGE=0.30
VALUE_MAX_GAME_TIME=1800
VALUE_TRADE_USD=5.0
VALUE_MAX_BOOK_AGE_MS=30000
VALUE_MAX_PER_MATCH=6

# Decisive swing strategy. Paper-only while ENABLE_REAL_LIVE_TRADING=false.
DSWING_ENABLED=true
DSWING_SHADOW_ENABLED=false
DSWING_LEAD=6000
DSWING_MIN_EDGE=0.05
DSWING_TRADE_USD=5.0

# Other non-entry surfaces, default off
ML_STRATEGY_ENABLED=false
ENABLE_MATCH_WINNER_TRADING=false

# Polymarket credentials. Required only for intentional real live trading.
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137
POLY_PRIVATE_KEY=
POLY_CLOB_API_KEY=
POLY_CLOB_SECRET=
POLY_CLOB_PASS_PHRASE=
POLY_SIGNATURE_TYPE=
POLY_FUNDER_ADDRESS=

# Optional alerts / ops
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISK_GUARD_PATH=/
DISK_GUARD_MIN_FREE_GB=2
DISK_GUARD_CHECK_INTERVAL_SEC=3600
