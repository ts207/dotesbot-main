STEAM_API_KEY=replace_me
MODE=paper

# Polling / reconnect
STEAM_POLL_SECONDS=0.5
WS_RECONNECT_SECONDS=5

# Signal safety thresholds
MAX_STEAM_AGE_MS=25000
REQUIRE_TOP_LIVE_FOR_SIGNALS=true
MAX_SOURCE_UPDATE_AGE_SEC=45
MAX_BOOK_AGE_MS=30000
MIN_LAG=0.08
MIN_EXECUTABLE_EDGE=0.03
PRICE_LOOKBACK_SEC=10
DEFAULT_MAX_FILL_PRICE=0.80
MAX_SPREAD=0.06
MIN_ASK_SIZE_USD=25

# Supervisor
CHECK_EVERY=30

# Strategy: Value
ENABLE_VALUE_TRADING=true
VALUE_MIN_EDGE=0.10
VALUE_MAX_PRICE=0.84
VALUE_MIN_NW_LEAD=3000
VALUE_MIN_GAME_TIME=600
VALUE_MIN_FAIR=0.0
VALUE_MAX_PER_MATCH=6.0

# Strategy: Decisive Swing
DSWING_ENABLED=false
DSWING_LEAD=6000
DSWING_MIN_EDGE=0.05
DSWING_MAX_PRICE=0.92
DSWING_MIN_GAME_TIME=600
DSWING_TRADE_USD=5.0

# Paper fill simulation
PAPER_MODE=research
PAPER_TRADE_SIZE_USD=25
PAPER_SLIPPAGE_CENTS=0.01
# Paper-only taker latency simulation. Set to 250, 500, 1000, etc. to test stale-liquidity survival.
PAPER_EXECUTION_DELAY_MS=0
MAX_OPEN_USD_PER_MATCH=150

# Event detection
EVENT_COOLDOWN_GAME_SECONDS=15

# Reaction-lag analysis
REACTION_WINDOW_SECONDS=30
BOOK_MOVE_MIN_CENTS=0.01

# Logs
CSV_LOG_PATH=logs/signals.csv
PAPER_TRADES_CSV_PATH=logs/paper_trades.csv
DOTA_EVENTS_CSV_PATH=logs/dota_events.csv
BOOK_EVENTS_CSV_PATH=logs/book_events.csv

# Position / PnL reports
POSITIONS_CSV_PATH=logs/positions.csv
PNL_SUMMARY_CSV_PATH=logs/pnl_summary.csv
LATENCY_CSV_PATH=logs/latency.csv
LIVE_LEAGUE_RAW_JSONL_PATH=logs/liveleague_raw.jsonl
RICH_CONTEXT_CSV_PATH=logs/rich_context.csv
SOURCE_DELAY_CSV_PATH=logs/source_delay.csv
MARKOUTS_CSV_PATH=logs/markouts.csv

# ---------------------------------------------------------------------------
# Guarded $10 live path test. Default is disabled. Read AGENTS.md before enabling.
# ---------------------------------------------------------------------------
LIVE_TRADING=false
ENABLE_REAL_LIVE_TRADING=false
MAX_TOTAL_LIVE_USD=10
MAX_TRADE_USD=1
MAX_OPEN_POSITIONS=1
MAX_DAILY_DRAWDOWN_USD=10
ORDER_TYPE=FAK
ALLOW_GAME_OVER_ONLY=false
ALLOW_EVENT_TRADES=true
ALLOW_CONFIRMATION_ONLY_LIVE_TRADES=false
DISABLE_STRUCTURE_TRADES=false
LIVE_REQUIRE_CADENCE_SCHEMA=true
LIVE_ALLOWED_CADENCE_QUALITIES=direct,normal
LIVE_MIN_EVENT_QUALITY=0.60
LIVE_TICK_SIZE=0.01
LIVE_SAFETY_MARGIN=0.02
LIVE_ATTEMPTS_CSV_PATH=logs/live_attempts.csv

# Polymarket CLOB credentials for live mode. Do not commit real values.
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137
POLY_PRIVATE_KEY=replace_me
POLY_CLOB_API_KEY=replace_me
POLY_CLOB_SECRET=replace_me
POLY_CLOB_PASS_PHRASE=replace_me
# POLY_SIGNATURE_TYPE=2
# POLY_FUNDER_ADDRESS=0x...

# Telegram notifications (ops/telegram_ops.py).
# Without these, the script logs to stdout and does not send.
# TELEGRAM_BOT_TOKEN=replace_me
# TELEGRAM_CHAT_ID=replace_me
# Set to true (manually or via cron) only while a Dota event is active so the
# liveness alert can fire when the bot goes idle during a known match window.
# DREAMLEAGUE_ACTIVE=false

# Disk guard (disk_guard.py). Halts new orders when free space drops below.
# DISK_GUARD_MIN_FREE_GB=2
# DISK_GUARD_PATH=/
# DISK_GUARD_CHECK_INTERVAL_SEC=3600
